---
---
<section class="py-24 border-b border-[#313244]">
  <div class="max-w-[1100px] mx-auto px-8">
    <div class="text-center mb-16 fade-in">
      <div class="font-mono text-xs text-[#6c7086] mb-4 flex items-center justify-center gap-2">
        <span class="text-[#585b70]">//</span>
        <span class="text-[#cba6f7]">const</span>
        <span class="text-[#a6e3a1]">KEYBINDS</span>
      </div>
      <h2 class="font-mono text-[clamp(26px,3.8vw,40px)] font-bold tracking-[-1.5px] text-[#cdd6f4]">
        Your hands never leave the keyboard.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-[1px] bg-[#313244] border border-[#313244] rounded-[10px] overflow-hidden fade-in">
      <!-- Copy Slots -->
      <div class="bg-[#1e1e2e] p-8">
        <div class="font-mono text-[11px] text-[#cba6f7] uppercase tracking-[1.5px] mb-5 flex items-center gap-2">
          <span class="text-[#a6e3a1]">></span> Copy Slots
        </div>
        <div class="flex items-center justify-between py-3 border-b border-[#313244]">
          <div class="flex gap-1 items-center">
            <span class="key">⌘</span><span class="key-plus">+</span><span class="key">C</span>
          </div>
          <span class="text-[13px] text-[#a6adc8]"><span class="text-[#6c7086]">→</span> default slot</span>
        </div>
        <div class="flex items-center justify-between py-3 border-b border-[#313244]">
          <div class="flex gap-1 items-center">
            <span class="key">⌘</span><span class="key-plus">+</span><span class="key">⇧</span><span class="key-plus">+</span><span class="key key-accent">1</span>
          </div>
          <span class="text-[13px] text-[#a6adc8]"><span class="text-[#6c7086]">→</span> slot 1</span>
        </div>
        <div class="flex items-center justify-between py-3 border-b border-[#313244]">
          <div class="flex gap-1 items-center">
            <span class="key">⌘</span><span class="key-plus">+</span><span class="key">⇧</span><span class="key-plus">+</span><span class="key key-accent">2</span>
          </div>
          <span class="text-[13px] text-[#a6adc8]"><span class="text-[#6c7086]">→</span> slot 2</span>
        </div>
        <div class="flex items-center justify-between py-3">
          <div class="flex gap-1 items-center">
            <span class="key">⌘</span><span class="key-plus">+</span><span class="key">⇧</span><span class="key-plus">+</span><span class="key key-accent">9</span>
          </div>
          <span class="text-[13px] text-[#a6adc8]"><span class="text-[#6c7086]">→</span> slot 9</span>
        </div>
      </div>

      <!-- Paste & Search -->
      <div class="bg-[#1e1e2e] p-8">
        <div class="font-mono text-[11px] text-[#cba6f7] uppercase tracking-[1.5px] mb-5 flex items-center gap-2">
          <span class="text-[#a6e3a1]">></span> Paste & Search
        </div>
        <div class="flex items-center justify-between py-3 border-b border-[#313244]">
          <div class="flex gap-1 items-center">
            <span class="key">⌘</span><span class="key-plus">+</span><span class="key">V</span>
          </div>
          <span class="text-[13px] text-[#a6adc8]"><span class="text-[#6c7086]">←</span> default slot</span>
        </div>
        <div class="flex items-center justify-between py-3 border-b border-[#313244]">
          <div class="flex gap-1 items-center">
            <span class="key">⌘</span><span class="key-plus">+</span><span class="key">⌥</span><span class="key-plus">+</span><span class="key key-accent">1</span>
          </div>
          <span class="text-[13px] text-[#a6adc8]"><span class="text-[#6c7086]">←</span> slot 1</span>
        </div>
        <div class="flex items-center justify-between py-3 border-b border-[#313244]">
          <div class="flex gap-1 items-center">
            <span class="key">⌘</span><span class="key-plus">+</span><span class="key">⇧</span><span class="key-plus">+</span><span class="key">V</span>
          </div>
          <span class="text-[13px] text-[#a6adc8]">history picker</span>
        </div>
        <div class="flex items-center justify-between py-3">
          <div class="flex gap-1 items-center">
            <span class="key">⌘</span><span class="key-plus">+</span><span class="key">⌥</span><span class="key-plus">+</span><span class="key">S</span>
          </div>
          <span class="text-[13px] text-[#a6adc8]">slot overlay</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px 10px;
    background: #313244;
    border: 1px solid #45475a;
    border-bottom: 3px solid #45475a;
    border-radius: 5px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    color: #cdd6f4;
    min-width: 28px;
    transition: transform 0.15s;
  }
  .key:hover {
    transform: translateY(-1px);
  }
  .key-accent {
    border-color: rgba(250, 179, 135, 0.3);
    color: #fab387;
    background: rgba(250, 179, 135, 0.08);
  }
  .key-plus {
    color: #6c7086;
    font-size: 11px;
    padding: 0 2px;
  }
</style>
