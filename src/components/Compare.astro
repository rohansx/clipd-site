---
<section id="compare" class="py-24 border-b border-[#313244] bg-[#181825]">
  <div class="max-w-[1100px] mx-auto px-8">
    <div class="text-center mb-16 fade-in">
      <div class="font-mono text-xs text-[#6c7086] mb-4 flex items-center justify-center gap-2">
        <span class="text-[#585b70]">//</span>
        <span class="text-[#cba6f7]">match</span>
        <span class="text-[#a6e3a1]">clipd</span>
        <span class="text-[#6c7086]">vs *</span>
      </div>
      <h2 class="font-mono text-[clamp(26px,3.8vw,40px)] font-bold tracking-[-1.5px] text-[#cdd6f4] mb-3">
        Not another clipboard manager.
      </h2>
      <p class="text-sm text-[#a6adc8] max-w-[500px] mx-auto">
        Every existing tool is either consumer-focused, Apple-only, or abandoned.
      </p>
    </div>

    <div class="overflow-x-auto border border-[#313244] rounded-[10px] bg-[#1e1e2e] fade-in">
      <table class="w-full border-collapse font-mono text-[13px]">
        <thead>
          <tr>
            <th class="p-3.5 text-left text-[11px] uppercase tracking-wider text-[#6c7086] font-medium bg-[#181825] border-b border-[#313244]"></th>
            <th class="p-3.5 text-left text-[11px] uppercase tracking-wider text-[#fab387] font-medium bg-[rgba(250,179,135,0.08)] border-b border-[#313244]">clipd</th>
            <th class="p-3.5 text-left text-[11px] uppercase tracking-wider text-[#6c7086] font-medium bg-[#181825] border-b border-[#313244]">Quip</th>
            <th class="p-3.5 text-left text-[11px] uppercase tracking-wider text-[#6c7086] font-medium bg-[#181825] border-b border-[#313244]">Maccy</th>
            <th class="p-3.5 text-left text-[11px] uppercase tracking-wider text-[#6c7086] font-medium bg-[#181825] border-b border-[#313244]">Paste</th>
            <th class="p-3.5 text-left text-[11px] uppercase tracking-wider text-[#6c7086] font-medium bg-[#181825] border-b border-[#313244]">CopyQ</th>
          </tr>
        </thead>
        <tbody>
          <tr class="hover:bg-[#181825]">
            <td class="p-3.5 text-[#a6adc8] border-b border-[#313244]">Multi-slot hotkeys</td>
            <td class="p-3.5 text-[#fab387] font-semibold bg-[rgba(250,179,135,0.08)] border-b border-[#313244]"><span class="text-[#a6e3a1]">●</span> 1-9</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
          </tr>
          <tr class="hover:bg-[#181825]">
            <td class="p-3.5 text-[#a6adc8] border-b border-[#313244]">Rich metadata</td>
            <td class="p-3.5 text-[#fab387] font-semibold bg-[rgba(250,179,135,0.08)] border-b border-[#313244]"><span class="text-[#a6e3a1]">●</span> SQLite</td>
            <td class="p-3.5 text-[#7f849c] border-b border-[#313244]">○ Basic</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#7f849c] border-b border-[#313244]">○ Basic</td>
            <td class="p-3.5 text-[#7f849c] border-b border-[#313244]">○ Basic</td>
          </tr>
          <tr class="hover:bg-[#181825]">
            <td class="p-3.5 text-[#a6adc8] border-b border-[#313244]">Terminal UI</td>
            <td class="p-3.5 text-[#fab387] font-semibold bg-[rgba(250,179,135,0.08)] border-b border-[#313244]"><span class="text-[#a6e3a1]">●</span> ratatui</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#7f849c] border-b border-[#313244]">○ CLI</td>
          </tr>
          <tr class="hover:bg-[#181825]">
            <td class="p-3.5 text-[#a6adc8] border-b border-[#313244]">Editor plugins</td>
            <td class="p-3.5 text-[#fab387] font-semibold bg-[rgba(250,179,135,0.08)] border-b border-[#313244]"><span class="text-[#a6e3a1]">●</span> MCP</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
          </tr>
          <tr class="hover:bg-[#181825]">
            <td class="p-3.5 text-[#a6adc8] border-b border-[#313244]">On-device AI</td>
            <td class="p-3.5 text-[#fab387] font-semibold bg-[rgba(250,179,135,0.08)] border-b border-[#313244]"><span class="text-[#a6e3a1]">●</span> ONNX</td>
            <td class="p-3.5 text-[#7f849c] border-b border-[#313244]">○ Apple</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
          </tr>
          <tr class="hover:bg-[#181825]">
            <td class="p-3.5 text-[#a6adc8] border-b border-[#313244]">E2E sync</td>
            <td class="p-3.5 text-[#fab387] font-semibold bg-[rgba(250,179,135,0.08)] border-b border-[#313244]"><span class="text-[#a6e3a1]">●</span> self-host</td>
            <td class="p-3.5 text-[#7f849c] border-b border-[#313244]">○ iCloud</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#7f849c] border-b border-[#313244]">○ iCloud</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
          </tr>
          <tr class="hover:bg-[#181825]">
            <td class="p-3.5 text-[#a6adc8] border-b border-[#313244]">Cross-platform</td>
            <td class="p-3.5 text-[#fab387] font-semibold bg-[rgba(250,179,135,0.08)] border-b border-[#313244]"><span class="text-[#a6e3a1]">●</span> All</td>
            <td class="p-3.5 text-[#7f849c] border-b border-[#313244]">○ Apple</td>
            <td class="p-3.5 text-[#7f849c] border-b border-[#313244]">○ Mac</td>
            <td class="p-3.5 text-[#7f849c] border-b border-[#313244]">○ Apple</td>
            <td class="p-3.5 text-[#a6e3a1] border-b border-[#313244]">● All</td>
          </tr>
          <tr class="hover:bg-[#181825]">
            <td class="p-3.5 text-[#a6adc8] border-b border-[#313244]">Open source</td>
            <td class="p-3.5 text-[#fab387] font-semibold bg-[rgba(250,179,135,0.08)] border-b border-[#313244]"><span class="text-[#a6e3a1]">●</span> MIT</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#a6e3a1] border-b border-[#313244]">● Yes</td>
            <td class="p-3.5 text-[#585b70] border-b border-[#313244]">—</td>
            <td class="p-3.5 text-[#a6e3a1] border-b border-[#313244]">● GPL</td>
          </tr>
          <tr class="hover:bg-[#181825]">
            <td class="p-3.5 text-[#a6adc8]">Price</td>
            <td class="p-3.5 text-[#fab387] font-semibold bg-[rgba(250,179,135,0.08)]"><span class="text-[#a6e3a1]">●</span> Free</td>
            <td class="p-3.5 text-[#7f849c]">$15/yr</td>
            <td class="p-3.5 text-[#a6e3a1]">$10</td>
            <td class="p-3.5 text-[#7f849c]">$30/yr</td>
            <td class="p-3.5 text-[#a6e3a1]">● Free</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>
